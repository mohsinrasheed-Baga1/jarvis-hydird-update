# JARVIS Hybrid API Keys
# Copy this file as .env and fill in your API keys
# These keys are used by the Electron main process for STT (voice-to-text) and TTS (text-to-speech)

# Groq API Key - Used for Whisper STT (voice transcription) and LLM chat
# Get yours at: https://console.groq.com/
GROQ_API_KEY=

# OpenAI API Key - Used for Whisper STT backup, TTS backup, and LLM chat
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini API Key - Used for LLM chat
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ElevenLabs API Key - Used for high-quality TTS (text-to-speech)
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Sarvam AI Key - Used for Hindi/Urdu TTS fallback
# Get yours at: https://sarvam.ai/
SARVAM_API_KEY=
